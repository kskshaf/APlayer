{
    "name": "aplayer",
    "version": "1.10.1",
    "description": "Wow, such a beautiful html5 music player",
    "main": "dist/APlayer.min.js",
    "style": "dist/APlayer.min.css",
    "scripts": {
        "start": "npm run dev",
        "build": "cross-env NODE_ENV=production webpack --config webpack/prod.config.js --progress",
        "dev": "cross-env NODE_ENV=development webpack serve --config webpack/dev.config.js",
        "test": "eslint src webpack",
        "format": "eslint \"**/*.js\" --fix && prettier \"**/*.{js,json,md}\" --write",
        "format:staged": "eslint \"**/*.js\" --fix && pretty-quick --staged --verbose --pattern \"**/*.{js,json,md}\"",
        "format:check": "eslint \"**/*.js\" && prettier \"**/*.{js,json,md}\" --check"
    },
    "files": [
        "dist"
    ],
    "repository": {
        "url": "git+https://github.com/DIYgod/APlayer.git",
        "type": "git"
    },
    "keywords": [
        "player",
        "music",
        "html5"
    ],
    "gitHooks": {
        "pre-commit": "npm run format:staged"
    },
    "author": "DIYgod",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/DIYgod/APlayer/issues"
    },
    "homepage": "https://github.com/DIYgod/APlayer#readme",
    "devDependencies": {
        "@babel/core": "^8.0.1",
        "@babel/preset-env": "^8.0.2",
        "@eslint/js": "^10.0.1",
        "@vuepress/plugin-back-to-top": "1.9.10",
        "@vuepress/plugin-google-analytics": "1.9.10",
        "@vuepress/plugin-pwa": "1.9.10",
        "art-template": "4.13.4",
        "art-template-loader": "1.4.3",
        "autoprefixer": "^10.5.2",
        "babel-loader": "^10.1.1",
        "cross-env": "^10.1.0",
        "css-loader": "^7.1.4",
        "cssnano": "^8.0.2",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "exports-loader": "^5.0.0",
        "file-loader": "^6.2.0",
        "git-revision-webpack-plugin": "^5.0.0",
        "globals": "^17.7.0",
        "mini-css-extract-plugin": "2.10.2",
        "postcss": "^8.5.16",
        "postcss-loader": "^8.2.1",
        "prettier": "^3.9.4",
        "pretty-quick": "^4.2.2",
        "sass": "^1.101.0",
        "sass-loader": "^17.0.0",
        "strip-loader": "^0.1.2",
        "style-loader": "^4.0.0",
        "svg-inline-loader": "0.8.2",
        "template-string-optimize-loader": "^3.0.0",
        "tslib": "^2.8.1",
        "url-loader": "^4.1.1",
        "vuepress": "1.9.10",
        "webpack": "^5.108.3",
        "webpack-cli": "7.1.0",
        "webpack-dev-server": "^6.0.0",
        "yorkie": "^2.0.0"
    },
    "dependencies": {
        "balloon-css": "^1.2.0",
        "promise-polyfill": "8.3.0",
        "smoothscroll": "0.4.0"
    }
}
